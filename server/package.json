{
  "name": "dapviz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others npm:dev:*",
    "dev:js": "vite",
    "dev:rust": "cd src-backend && cargo watch -- cross-env RUST_LOG=\"debug\" LOG_OUTPUT=\"stderr\" cargo run -- launch --port 8080 --debug-adapter netcoredbg \"../../playground/csharp/bin/Debug/net10.0/csharp.dll\"",
    "build": "npm run build:js && npm run build:rust",
    "build:js": "tsc && vite build",
    "build:rust": "cd src-backend && cargo build --release",
    "lint": "npm run lint:js && npm run lint:rust",
    "lint:js": "eslint src/ && prettier . --check",
    "lint:rust": "cd src-backend && cargo check",
    "lint:fix": "npm run lint:fix:rust && npm run lint:fix:js",
    "lint:fix:js": "eslint src/ --fix && prettier . --write",
    "lint:fix:rust": "cd src-backend && cargo fix"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@unocss/reset": "^66.6.6",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-wind4": "^66.6.6",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unocss": "^66.6.6",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "packageManager": "pnpm@10.31.0"
}
